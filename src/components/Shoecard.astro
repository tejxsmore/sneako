---
import { Image, Picture } from "@astrojs/image/components";

const {
  id,
  url,
  title,
  price,
  color,
  category,
  image,
  otherImages,
  description,
} = Astro.props;
---

<a href={url} id="shoecard" class="p-3 m-3 border-2 border-gray-600 rounded-sm">
  <Image src={image} alt={title} width={400} height={400} format="avif" />
  <h1 class="font-semibold pt-2">{title}</h1>
  <p class="text-gray-500">{category}'s shoes</p>
  <p class="font-semibold pt-2">₹{price.toLocaleString()}</p>
</a>

<style>
  img {
    width: 322px;
  }
</style>
