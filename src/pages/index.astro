---
import MainLayout from "../layouts/MainLayout.astro";
import Label from "../components/Label.astro";
import { featured } from "../../public/store/nike/featured";
import Shoecard from "../components/Shoecard.astro";
---

<MainLayout>
  <div class="p-3 sm:px-32">
    <div class="flex flex-wrap justify-center">
      {
        featured.map(
          ({
            id,
            title,
            price,
            color,
            url,
            category,
            image,
            otherImages,
            description,
          }) => (
            <Shoecard
              {id}
              {title}
              {price}
              {color}
              {url}
              {category}
              {image}
              {otherImages}
              {description}
            />
          )
        )
      }
    </div>
  </div>
</MainLayout>
