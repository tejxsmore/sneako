---
import BrandLayout from "../../layouts/BrandLayout.astro";
import Label from "../../components/Label.astro";
import Shoecard from "../../components/Shoecard.astro";
import { featured } from "../../../public/store/adidas/featured";
---

<BrandLayout
  title="Sneaker Spot - ADIDAS"
  brand="adidas"
  image="https://img.freepik.com/free-icon/adidas_318-565831.jpg"
>
  <div class="p-3">
    <Label brand="adidas" type1="sneakers" type2="running" type3="football" />

    <div class="flex flex-wrap">
      {
        featured.map(
          ({
            id,
            title,
            price,
            color,
            url,
            category,
            image,
            otherImages,
            description,
          }) => (
            <Shoecard
              {id}
              {title}
              {price}
              {color}
              {url}
              {category}
              {image}
              {otherImages}
              {description}
            />
          )
        )
      }
    </div>
  </div>
</BrandLayout>
