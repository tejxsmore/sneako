---
export function getStaticPaths() {
  return [
    { params: { id: 0 } },
    { params: { id: 1 } },
    { params: { id: 2 } },
    { params: { id: 3 } },
    { params: { id: 4 } },
    { params: { id: 5 } },
    { params: { id: 6 } },
    { params: { id: 7 } },
  ];
}

const { id } = Astro.params;

import { sneakers } from "../../../../../public/store/adidas/sneakers";
import Details from "../../../../components/Details.astro";
---

{
  id && (
    <Details
      title={sneakers[id]?.title}
      brand={sneakers[id]?.brand}
      brandLogo={sneakers[id].brandLogo}
      price={sneakers[id]?.price}
      color={sneakers[id]?.title}
      image={sneakers[id]?.image}
      category={sneakers[id]?.category}
      otherImages={sneakers[id]?.otherImages}
      description={sneakers[id]?.description}
    />
  )
}
