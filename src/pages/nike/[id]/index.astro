---
export function getStaticPaths() {
  return [
    { params: { id: 0 } },
    { params: { id: 1 } },
    { params: { id: 2 } },
    { params: { id: 3 } },
    { params: { id: 4 } },
    { params: { id: 5 } },
    { params: { id: 6 } },
    { params: { id: 7 } },
  ];
}

const { id } = Astro.params;

import { featured } from "../../../../public/store/nike/featured";
import Details from "../../../components/Details.astro";
---

{
  id && (
    <Details
      title={featured[id]?.title}
      brand={featured[id]?.brand}
      brandLogo={featured[id].brandLogo}
      price={featured[id]?.price}
      color={featured[id]?.title}
      image={featured[id]?.image}
      category={featured[id]?.category}
      otherImages={featured[id]?.otherImages}
      description={featured[id]?.description}
    />
  )
}
