---
import BrandLayout from "../../layouts/BrandLayout.astro";
import { featured } from "../../../public/store/puma/featured";
import Shoecard from "../../components/Shoecard.astro";
import Label from "../../components/Label.astro";
---

<BrandLayout
  title="SNEAKO - Puma"
  brand="puma"
  image="https://seeklogo.com/images/P/puma-se-logo-ACC0F72575-seeklogo.com.png"
>
  <div class="p-3 sm:px-32">
    <Label brand="puma" type1="sneakers" type2="running" type3="football" />

    <div class="flex flex-wrap justify-center">
      {
        featured.map(
          ({
            id,
            title,
            price,
            color,
            url,
            category,
            image,
            otherImages,
            description,
          }) => (
            <Shoecard
              {id}
              {title}
              {price}
              {color}
              {url}
              {category}
              {otherImages}
              {image}
              {description}
            />
          )
        )
      }
    </div>
  </div>
</BrandLayout>
